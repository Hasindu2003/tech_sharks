@page
@model HRMS.UI.Pages.Training.ViewProfileModel
@{
    Layout = null;
    bool isIntern = string.Equals(Model.EmpType, "Intern", StringComparison.OrdinalIgnoreCase);
    var themeColor = isIntern ? "#ca8a04" : "#15803d"; 
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profile - @Model.FullName</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --sidebar-width: 260px;
            --main-green: #15803d; 
            --active-green-bg: #f0fdf4;
            --bg-body: #f8fafc;
            --text-gray: #6b7280;
        }
        body { font-family: 'Inter', system-ui, sans-serif; background-color: var(--bg-body); margin: 0; }
        .sidebar {
            width: var(--sidebar-width); height: 100vh; background: #ffffff;
            position: fixed; left: 0; top: 0; z-index: 1000;
            border-right: 1px solid #e2e8f0; display: flex; flex-direction: column;
        }
        .sidebar-header { padding: 20px 25px; }
        .sidebar-logo-text { font-weight: 700; color: #111827; font-size: 1rem; margin-bottom: 0; }
        .sidebar-sub-text { font-size: 0.7rem; color: var(--text-gray); }
        .nav-list { padding: 20px 10px; flex-grow: 1; }
        .nav-link {
            display: flex; align-items: center; padding: 12px 20px; color: #4b5563;
            text-decoration: none; border-radius: 8px; margin-bottom: 5px; font-size: 0.9rem;
        }
        .nav-link i { margin-right: 12px; font-size: 1.1rem; }
        .nav-link:hover, .nav-link.active { background: var(--active-green-bg); color: var(--main-green); }
        .logout-container { padding: 20px; }
        .logout-btn { background: #15803d; color: white !important; width: 100%; border-radius: 8px; justify-content: center; }
        .main-wrapper { margin-left: var(--sidebar-width); width: calc(100% - var(--sidebar-width)); }
        .top-navbar {
            height: 70px; background: #ffffff; padding: 0 40px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 900; border-bottom: 1px solid #f1f5f9;
        }
        .topbar-title { font-size: 1.2rem; font-weight: 600; color: #111827; margin: 0; }
        .topbar-actions { display: flex; align-items: center; gap: 20px; }
        .icon-btn { color: #6b7280; font-size: 1.2rem; cursor: pointer; position: relative; }
        .notification-dot { position: absolute; top: -2px; right: -2px; width: 8px; height: 8px; background: #ef4444; border-radius: 50%; border: 2px solid white; }
        .user-avatar { width: 35px; height: 35px; border-radius: 50%; object-fit: cover; }
        .page-content { padding: 35px; }
        .content-card { background: white; border-radius: 12px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); overflow: hidden; }
        .status-pill { padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; display: inline-flex; align-items: center; gap: 6px; }
        .status-intern { background: #fef9c3; color: #a16207; }
        .status-probation { background: #dcfce7; color: #15803d; }
    </style>
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-header">
            <p class="sidebar-logo-text">Kanrich HRMS</p>
            <p class="sidebar-sub-text">Admin Portal</p>
        </div>
        <nav class="nav-list">
            <a href="#" class="nav-link"><i class="bi bi-grid"></i> Dashboard</a>
            <a href="#" class="nav-link"><i class="bi bi-people"></i> Employees</a>
            <a href="/Training/Dashboard" class="nav-link active"><i class="bi bi-mortarboard"></i> Training</a>
            <a href="#" class="nav-link"><i class="bi bi-calendar3"></i> Calendar</a>
            <a href="#" class="nav-link"><i class="bi bi-arrow-left-right"></i> Separation</a>
        </nav>
        <div class="logout-container">
            <a href="#" class="nav-link logout-btn">Log Out</a>
        </div>
    </aside>

    <div class="main-wrapper">
        <header class="top-navbar">
            <div class="d-flex align-items-center">
                <a href="/Training/Dashboard" class="btn btn-light btn-sm rounded-circle me-3"><i class="bi bi-chevron-left"></i></a>
                <h1 class="topbar-title">Employee Profile</h1>
            </div>
            <div class="topbar-actions">
                <div class="icon-btn"><i class="bi bi-bell"></i><span class="notification-dot"></span></div>
                <div class="icon-btn"><i class="bi bi-gear"></i></div>
                <img src="https://ui-avatars.com/api/?name=Admin&background=15803d&color=fff" class="user-avatar" alt="User">
            </div>
        </header>

        <main class="page-content">
            <div class="content-card">
                <div class="p-4 border-bottom">
                    <div class="d-flex align-items-center">
                        <img src="https://ui-avatars.com/api/?name=@Model.FullName&background=random" class="rounded-circle border me-4" width="80">
                        <div>
                            <h3 class="fw-bold text-dark mb-1">@Model.FullName</h3>
                            <div class="d-flex align-items-center gap-2">
                                @if (isIntern) {
                                    <span class="status-pill status-intern"><i class="bi bi-mortarboard-fill"></i> Internship</span>
                                } else {
                                    <span class="status-pill status-probation"><i class="bi bi-patch-check-fill"></i> Probation Period</span>
                                }
                                <span class="text-muted small">ID: #@Model.EmpId</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="p-4">
                    <h6 class="fw-bold text-dark mb-4">Performance Trend (6 Months)</h6>
                    <div style="height: 320px;">
                        <canvas id="performanceChart"></canvas>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        const ctx = document.getElementById('performanceChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Month 1', 'Month 2', 'Month 3', 'Month 4', 'Month 5', 'Month 6'],
                datasets: [{
                    label: 'Score %',
                    data: @Html.Raw(Json.Serialize(Model.MonthlyScores)),
                    borderColor: '@themeColor',
                    backgroundColor: '@(isIntern ? "rgba(202, 138, 4, 0.1)" : "rgba(21, 128, 61, 0.1)")',
                    borderWidth: 3, tension: 0.3, fill: true, pointRadius: 5, pointBackgroundColor: '#fff'
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                scales: { y: { beginAtZero: true, max: 100 }, x: { grid: { display: false } } },
                plugins: { legend: { display: false } }
            }
        });
    </script>
</body>
</html>